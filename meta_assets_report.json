  "flows": [
    {
      "id": "3141848516022930",
      "json": {
        "version": "7.3",
        "screens": [
          {
            "id": "DASHBOARD",
            "title": "Dashboard Inventario",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "TextHeading",
                  "text": "📦 Gestión de Stock Arise"
                },
                {
                  "type": "TextBody",
                  "text": "Seleccione una acción para gestionar su inventario industrial en tiempo real."
                },
                {
                  "type": "Dropdown",
                  "label": "Acción Requerida",
                  "name": "inventory_action",
                  "required": true,
                  "data-source": [
                    {
                      "id": "view_stock",
                      "title": "Ver Alertas de Stock Bajo"
                    },
                    {
                      "id": "add_stock",
                      "title": "Registrar Entrada de Mercancía"
                    },
                    {
                      "id": "remove_stock",
                      "title": "Registrar Salida / Venta"
                    }
                  ]
                },
                {
                  "type": "Footer",
                  "label": "Continuar",
                  "on-click-action": {
                    "name": "data_exchange",
                    "payload": {
                      "action": "${form.inventory_action}"
                    }
                  }
                }
              ]
            }
          },
          {
            "id": "SUCCESS",
            "title": "Operación Exitosa",
            "terminal": true,
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "TextHeading",
                  "text": "✅ Solicitud Procesada"
                },
                {
                  "type": "TextBody",
                  "text": "Su solicitud ha sido enviada al Procesador Neural. Recibirá una confirmación en este chat en breve."
                },
                {
                  "type": "Footer",
                  "label": "Finalizar",
                  "on-click-action": {
                    "name": "complete",
                    "payload": {
                      "status": "success"
                    }
                  }
                }
              ]
            }
          }
        ],
        "data_api_version": "4.0",
        "routing_model": {
          "DASHBOARD": [
            "SUCCESS"
          ],
          "SUCCESS": []
        }
      }
    }
  ]
}