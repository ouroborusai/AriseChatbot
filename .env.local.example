# Copiar a .env.local y rellenar (Next.js carga .env.local automáticamente).

# Meta → Developer App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Mismo valor que configures al suscribir el webhook en Meta (libre, tú lo inventas)
WHATSAPP_VERIFY_TOKEN=

# IA en webhook: si GEMINI_API_KEY está definida se usa Gemini; si no, OPENAI_API_KEY (OpenAI).
GEMINI_API_KEY=
# Por defecto en código: gemini-1.5-flash (mejor cuota en tier gratuito que 2.0)
# GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor (webhook); no exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=
