{
  "version": "3.0",
  "screens": [
    {
      "id": "QUESTIONNAIRE",
      "title": "Registro de Interés",
      "data": {
        "catalog_id": {
          "type": "string",
          "default": "default_catalog"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "¡Bienvenido a Arise!"
          },
          {
            "type": "TextBody",
            "text": "Completa tus datos para recibir una oferta personalizada de nuestro catálogo."
          },
          {
            "type": "TextInput",
            "label": "Nombre Completo",
            "name": "full_name",
            "required": true,
            "input-type": "text"
          },
          {
            "type": "Dropdown",
            "label": "¿Qué categoría buscas?",
            "name": "category_selection",
            "required": true,
            "options": [
              {
                "id": "electronics",
                "title": "Electrónica y Gadgets"
              },
              {
                "id": "home",
                "title": "Hogar y Decoración"
              },
              {
                "id": "fashion",
                "title": "Moda y Accesorios"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Enviar Datos",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "full_name": "${form.full_name}",
                "category": "${form.category_selection}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "¡Todo Listo!",
      "terminal": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "¡Registro Exitoso!"
          },
          {
            "type": "TextBody",
            "text": "Hemos recibido tus datos. En unos segundos recibirás una selección de productos recomendados directamente en este chat."
          },
          {
            "type": "Footer",
            "label": "Cerrar",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "status": "success"
              }
            }
          }
        ]
      }
    }
  ]
}
